---
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>ChatGPT App</title>
    <style>
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html, body { height: 100%; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        background: #212121;
        color: #e3e3e3;
      }
      .app-shell {
        display: flex;
        height: 100vh;
      }
      .sidebar-slot {
        width: 260px;
        flex-shrink: 0;
        background: #171717;
        border-right: 1px solid #2f2f2f;
      }
      .content-slot {
        flex: 1;
        display: flex;
        flex-direction: column;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <div class="app-shell">
      <aside class="sidebar-slot">
        <slot name="sidebar" />
      </aside>
      <main class="content-slot">
        <slot />
      </main>
    </div>
  </body>
</html>
